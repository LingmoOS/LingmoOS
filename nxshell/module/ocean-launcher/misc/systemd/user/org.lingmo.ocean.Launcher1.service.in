[Unit]
Description=OCEAN launcher service

[Service]
ExecStart=@CMAKE_INSTALL_FULL_BINDIR@/ocean-launcher
Type=dbus
BusName=org.lingmo.ocean.Launcher1
Restart=on-failure
RestartSec=1s
