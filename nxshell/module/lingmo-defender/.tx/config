[main]
host = https://www.transifex.com
minimum_perc = 80
mode = developer

[lingmo-defender.lingmo-defender]
file_filter = lingmo-defender/translations/lingmo-defender_<lang>.ts
source_file = lingmo-defender/translations/lingmo-defender_en_US.ts
source_lang = en
type = QT

[lingmo-defender.lingmo-defender-desktop]
file_filter = lingmo-defender/translations/desktop/desktop_<lang>.ts
source_file = lingmo-defender/translations/desktop/desktop.ts
source_lang = en
type = QT

[lingmo-defender.lingmo-defender-scandesktop]
file_filter = lingmo-defender/translations/scandesktop/desktop_<lang>.ts
source_file = lingmo-defender/translations/scandesktop/desktop.ts
preTranslate_file = lingmo-defender/lingmo-defender-nativirus.desktop
source_lang = en
type = QT

[lingmo-defender.lingmo-defender-policy]
file_filter = lingmo-defender/translations/policy/policy_<lang>.ts
source_file = lingmo-defender/translations/policy/policy.ts
preTranslate_file = lingmo-defender/com.lingmo.lingmo-defender
source_lang = en
type = QT

[lingmo-defender.lingmo-defender-datainterface]
file_filter = lingmo-defender-server/lingmo-defender-datainterface/translations/lingmo-defender-datainterface_<lang>.ts
source_file = lingmo-defender-server/lingmo-defender-datainterface/translations/lingmo-defender-datainterface_en_US.ts
source_lang = en
type = QT