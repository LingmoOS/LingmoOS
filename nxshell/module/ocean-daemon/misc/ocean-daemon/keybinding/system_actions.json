{
    "Actions": [
        {
            "Action": "dbus-send --print-reply --dest=org.lingmo.ocean.Launcher1 /org/lingmo/ocean/Launcher1 org.lingmo.ocean.Launcher1.Toggle",
            "Key": "launcher"
        },
        {
            "Action": "/usr/lib/lingmo-daemon/default-terminal",
            "Key": "terminal"
        },
        {
            "Key": "lingmo-screen-recorder",
            "Action": "dbus-send --print-reply --dest=com.lingmo.ScreenRecorder /com/lingmo/ScreenRecorder com.lingmo.ScreenRecorder.stopRecord"
        },
        {
            "Key": "system-monitor",
            "Action": "ocean-am lingmo-system-monitor"
        },
        {
            "Key": "lingmo-picker",
            "Action": "dbus-send --print-reply --dest=com.lingmo.Picker /com/lingmo/Picker com.lingmo.Picker.Show"
        },
        {
            "Action": "/usr/lib/lingmo-daemon/ocean-lock.sh",
            "Key": "lock-screen"
        },
        {
            "Action": "dbus-send --print-reply --dest=org.lingmo.ocean.ShutdownFront1 /org/lingmo/ocean/ShutdownFront1 org.lingmo.ocean.ShutdownFront1.Show",
            "Key": "logout"
        },
        {
            "Action": "lingmo-terminal --quake-mode",
            "Key": "terminal-quake"
        },
        {
            "Action": "dbus-send --print-reply --dest=com.lingmo.Screenshot /com/lingmo/Screenshot com.lingmo.Screenshot.StartScreenshot",
            "Key": "screenshot"
        },
        {
            "Action": "dbus-send --print-reply --dest=com.lingmo.Screenshot /com/lingmo/Screenshot com.lingmo.Screenshot.FullscreenScreenshot",
            "Key": "screenshot-fullscreen"
        },
        {
            "Action": "dbus-send --print-reply --dest=com.lingmo.Screenshot /com/lingmo/Screenshot com.lingmo.Screenshot.TopWindowScreenshot",
            "Key": "screenshot-window"
        },
        {
            "Action": "dbus-send --print-reply --dest=com.lingmo.Screenshot /com/lingmo/Screenshot com.lingmo.Screenshot.DelayScreenshot int64:5",
            "Key": "screenshot-delayed"
        },
        {
            "Action": "/usr/lib/lingmo-daemon/default-file-manager",
            "Key": "file-manager"
        },
        {
            "Action": "gsettings set com.lingmo.ocean.touchpad touchpad-enabled false",
            "Key": "disable-touchpad"
        },
        {
            "Action": "dbus-send --type=method_call --dest=org.lingmo.ocean.WMSwitcher1 /org/lingmo/ocean/WMSwitcher1 org.lingmo.ocean.WMSwitcher1.RequestSwitchWM",
            "Key": "wm-switcher"
        },
        {
            "Action": "sleep 0.5; xset dpms force off",
            "Key": "turn-off-screen"
        },
        {
            "Key": "ai-assistant",
            "Action": "dbus-send  --print-reply --dest=com.iflytek.aiassistant /aiassistant/lingmomain com.iflytek.aiassistant.mainWindow.changeui"
        },
        {
            "Key": "text-to-speech",
            "Action": "/usr/share/uos-ai-assistant/shell/tts.sh"
        },
        {
            "Key": "speech-to-text",
            "Action": "dbus-send  --print-reply --dest=com.iflytek.aiassistant /aiassistant/lingmomain com.iflytek.aiassistant.mainWindow.SpeechToText"
        },
        {
            "Key": "clipboard",
            "Action": "dbus-send --print-reply --dest=org.lingmo.ocean.Clipboard1 /org/lingmo/ocean/Clipboard1 org.lingmo.ocean.Clipboard1.Toggle"
        },
        {
            "Key": "translation",
            "Action": "dbus-send  --print-reply --dest=com.iflytek.aiassistant /aiassistant/lingmomain com.iflytek.aiassistant.mainWindow.TextToTranslate"
        },
		{
            "key":"notification-center",
            "Action":"dbus-send --print-reply --dest=org.lingmo.ocean.Widgets1 /org/lingmo/ocean/Widgets1 org.lingmo.ocean.Widgets1.Toggle"
        },
        {
            "Key": "screenshot-ocr",
            "Action": "dbus-send --print-reply --dest=com.lingmo.Screenshot /com/lingmo/Screenshot com.lingmo.Screenshot.OcrScreenshot"
        },
		{
            "key":"screenshot-scroll",
            "Action": "dbus-send --print-reply --dest=com.lingmo.Screenshot /com/lingmo/Screenshot com.lingmo.Screenshot.ScrollScreenshot"
        }

    ]
}
