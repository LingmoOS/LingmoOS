[Unit]
Description=Portal service (Lingmo implementation)
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=dbus
BusName=org.freedesktop.impl.portal.desktop.ocean
ExecStart=@CMAKE_INSTALL_FULL_LIBEXECDIR@/xdg-desktop-portal-ocean
Restart=on-failure
RestartPreventExitStatus=1
