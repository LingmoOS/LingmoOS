# Maintainer: justforlxz <justforlxz@gmail.com>
pkgname=lingmo-app-services-git
pkgver=5.5.23.r5.g74f86b0
pkgrel=1
sourcename=ocean-app-services
sourcetars=("$sourcename"_"$pkgver".tar.xz)
sourcedir="$sourcename"
pkgdesc='Service collection of OCEAN applications, including dconfig-center'
arch=('x86_64' 'aarch64')
url="https://github.com/lingmoos/ocean-app-services"
license=('LGPL3')
depends=('dtkwidget-git' 'gtest')
makedepends=('git' 'ninja' 'cmake' 'qt5-tools' 'doxygen')
conflicts=('lingmo-app-services')
provides=('lingmo-app-services')
groups=('lingmo-git')
source=("${sourcetars[@]}")
sha512sums=('SKIP')

build() {
	cd $sourcedir
	cmake -GNinja \
		-DCMAKE_INSTALL_LIBDIR=lib \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_BUILD_TYPE=Release
	ninja
}

package() {
	cd $sourcedir
	DESTDIR="$pkgdir" ninja install
}
