# Maintainer: justforlxz <justforlxz@gmail.com>

pkgname=lingmo-network-core-git
pkgver=1.0.45
pkgrel=1
sourcename=ocean-network-core
sourcedir="$sourcename"
sourcetars=("$sourcename"_"$pkgver".tar.xz)
pkgdesc='the library of network libocean-network-core module'
arch=('x86_64' 'aarch64')
url="https://github.com/lingmoos/ocean-network-core"
license=('GPL3')
depends=('lingmo-qt-dbus-factory-git' 'gio-qt' 'gsettings-qt' 'networkmanager-qt5' 'lingmo-session-shell-git' 'lingmo-dock-git'
	  'lingmo-control-center-git')
makedepends=('qt5-tools' 'cmake' 'ninja' 'gtest' 'dtkcommon-git')
conflicts=('lingmo-network-core' 'lingmo-network-utils-git')
provides=('lingmo-network-core' 'lingmo-network-utils-git')
groups=('lingmo-git')
source=("${sourcetars[@]}")
sha512sums=('SKIP')

build() {
  cd $sourcedir
  cmake -B build -GNinja -DCMAKE_INSTALL_PREFIX=/usr
  cmake --build build
}

package() {
  cd $sourcedir
  DESTDIR="$pkgdir" ninja -C build install
}
