#!/usr/bin/make -f

export QT_SELECT=5

DISTRO = $(shell lsb_release -is)
ifeq ($(DISTRO),Lingmo)
	USE_LINGMO_POLKIT=ON
else ifeq ($(DISTRO),uos)
    USE_LINGMO_POLKIT=ON
else
	USE_LINGMO_POLKIT=OFF
endif

%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- -DUSE_LINGMO_POLKIT=$(USE_LINGMO_POLKIT)
