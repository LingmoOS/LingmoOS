@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(Dtk@DTK_VERSION_MAJOR@Core)
find_dependency(Dtk@DTK_VERSION_MAJOR@Gui)
find_package(Qt@QT_VERSION_MAJOR@ COMPONENTS Qml Quick REQUIRED)

include(${CMAKE_CURRENT_LIST_DIR}/OCEANShellTargets.cmake)
set(OCEAN_SHELL_PACKAGE_INSTALL_DIR @CMAKE_INSTALL_PREFIX@/@OCEAN_SHELL_PACKAGE_INSTALL_DIR@)
set(OCEAN_SHELL_PLUGIN_INSTALL_DIR @CMAKE_INSTALL_PREFIX@/@OCEAN_SHELL_PLUGIN_INSTALL_DIR@)
set(OCEAN_SHELL_TRANSLATION_INSTALL_DIR @CMAKE_INSTALL_PREFIX@/@OCEAN_SHELL_TRANSLATION_INSTALL_DIR@)
check_required_components(Dtk@DTK_VERSION_MAJOR@Core)

include("${CMAKE_CURRENT_LIST_DIR}/OCEANShellPackageMacros.cmake")
