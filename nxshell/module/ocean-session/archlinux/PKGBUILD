pkgname=lingmo-session-git
_pkgname=lingmo-session-git
pkgver=1.1.4
pkgrel=1
sourcename=ocean-session
sourcetars=("$sourcename"_"$pkgver".tar.xz)
sourcedir="$sourcename"
pkgdesc='lingmo session'
arch=('x86_64' 'aarch64')
url="https://github.com/lingmoos/ocean-session"
license=('GPL3')
depends=('dtkcore-git' 'libsystemd' 'doxygen' 'glib2'
         'libxcursor' 'libx11' 'libxfixes'
         'gsettings-qt' 'libsecret')
makedepends=('git' 'cmake' 'ninja' 'pkgconf')
conflicts=('lingmo-session')
provides=('lingmo-session')
groups=('lingmo-git')
source=("${sourcetars[@]}")
sha512sums=('SKIP')
prepare() {
    cd $sourcedir
}

build() {
  cd $sourcedir
  cmake -GNinja \
        -DCMAKE_INSTALL_PREFIX=/usr
  ninja
}

package() {
  cd $sourcedir
  DESTDIR="$pkgdir" ninja install
}
