# Maintainer: justforlxz <justforlxz@gmail.com>
pkgname=lingmo-polkit-agent-ext-gnomekeyring-git
pkgver=5.0.11.r1.g6f049dc
pkgrel=1
sourcename=dpa-ext-gnomekeyring
sourcetars=("$sourcename"_"$pkgver".tar.xz)
sourcedir="$sourcename"
pkgdesc="GNOME keyring extension for ocean-polkit-agent"
arch=('x86_64' 'aarch64')
url="https://github.com/lingmoos/dpa-ext-gnomekeyring"
license=('GPL3')
depends=('lingmo-polkit-agent-git' 'libgnome-keyring')
makedepends=('git' 'cmake' 'ninja' 'qt5-tools' 'libgnome-keyring' 'lingmo-polkit-agent-git')
conflicts=('lingmo-polkit-agent-ext-gnomekeyring')
provides=('lingmo-polkit-agent-ext-gnomekeyring')
groups=('lingmo-git')
source=("${sourcetars[@]}")
sha512sums=('SKIP')

prepare() {
    cd $sourcedir
}

build() {
  cd $sourcedir
  cmake . -G Ninja -DCMAKE_INSTALL_PREFIX=/usr
  ninja
}

package() {
  cd $sourcedir
  DESTDIR="$pkgdir" ninja install
}
