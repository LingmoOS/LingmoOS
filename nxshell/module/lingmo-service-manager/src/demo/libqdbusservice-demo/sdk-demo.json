                        },
                        {
                            "method": "Hello",
                            "permission": false
                        }
                    ],
                    "properties": [
                        {
                            "property": "Age",
                            "permission": false
                        }
                    ]
                }
            ]
        },
        {
            "path": "/org/lingmo/services/sdk/test1",
            "pathhide": true,
            "permission": false
        }
    ]
