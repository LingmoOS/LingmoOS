{
    "name": "org.lingmo.service.sdk.demo",
    "policyStartType": "OnDemand",
    "idleTime": 1,
    "whitelists": [
        {
            "name": "w1",
            "process": [
                "/usr/bin/aaa",
                "/usr/bin/bbb",
                "/usr/bin/python3"
            ]
        },
        {
            "name": "w2",
            "process": [
                "/usr/bin/aaa",
                "/usr/bin/ccc"
            ]
        }
    ],
    "policy": [
        {
            "path": "/org/lingmo/service/sdk/demo",
            "pathhide": false,
