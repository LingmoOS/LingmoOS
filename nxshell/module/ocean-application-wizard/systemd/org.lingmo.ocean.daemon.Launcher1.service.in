[Unit]
Description=Legacy OCEAN Application Manager launcher daemon compat background service

[Service]
ExecStart=@CMAKE_INSTALL_FULL_LIBEXECDIR@/ocean-application-wizard-daemon-compat
Type=dbus
BusName=org.lingmo.ocean.daemon.Launcher1
Restart=on-failure
RestartSec=1s
