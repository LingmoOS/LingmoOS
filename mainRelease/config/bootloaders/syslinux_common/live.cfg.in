label live-@FLAVOUR@
        menu label ^Boot Lingmo OS (@FLAVOUR@)
        menu default
        linux @LINUX@
        initrd @INITRD@
        append @APPEND_LIVE@

label live-@FLAVOUR@-failsafe
        menu label Boot Lingmo OS (@FLAVOUR@ fail-safe mode)
        linux @LINUX@
        initrd @INITRD@
        append @APPEND_LIVE_FAILSAFE@

label live-forensic
        menu label Boot Lingmo OS (@FLAVOUR@ ^forensic mode)
        linux @LINUX@
        initrd @INITRD@
        append boot=live username=lingmo hostname=lingmo systemd.swap=no noautomount

label live-persistence
        menu label Boot Lingmo OS with ^USB persistence  (check lingmo.org/prst)
        linux @LINUX@
        initrd @INITRD@
        append boot=live username=lingmo hostname=lingmo persistence

label live-encrypted-persistence
	menu label Boot Lingmo OS with USB ^Encrypted persistence
        linux @LINUX@
        initrd @INITRD@
        append boot=live persistent=cryptsetup persistence-encryption=luks username=lingmo hostname=lingmo persistence

