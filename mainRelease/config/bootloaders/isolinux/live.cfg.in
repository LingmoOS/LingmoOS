menu hshift 0
menu width 82
include stdmenu.cfg

label live-amd64
	menu label ^Start Lingmo OS LiveCD (amd64)
	menu default
	linux @LINUX@
	initrd @INITRD@
	append boot=live username=lingmo hostname=lingmo components quiet splash

label live-amd64-failsafe
	menu label Start Lingmo OS LiveCD (amd64 fail-safe mode)
	linux @LINUX@
	initrd @INITRD@
	append boot=live username=lingmo hostname=lingmo components memtest noapic noapm nodma nomce nolapic nosmp nosplash vga=788
