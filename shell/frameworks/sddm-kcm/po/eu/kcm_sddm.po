msgstr "Ezin da gaia instalatu"

#: src/sddmkcm.cpp:164 src/sddmkcm.cpp:302
msgid ""
"Cannot proceed, user 'sddm' does not exist. Please check your SDDM install."
msgstr ""
"Ezin du jarraitu, 'sddm' erabiltzailea ez da existitzen. Mesedez, ikuskatu "
"zure SDDMren instalazioa."

