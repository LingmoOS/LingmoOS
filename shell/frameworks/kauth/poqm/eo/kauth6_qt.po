#: backends/dbus/DBusHelperProxy.cpp:84
#, qt-format
msgctxt "KAuth::DBusHelperProxy|"
msgid "DBus Backend error: service start %1 failed: %2"
msgstr "DBus-Backend eraro: serv-ekfunkciigo %1 malsukcesis: %2"

#: backends/dbus/DBusHelperProxy.cpp:99
#, qt-format
msgctxt "KAuth::DBusHelperProxy|"
msgid ""
"DBus Backend error: connection to helper failed. %1\n"
"(application: %2 helper: %3)"
msgstr ""
"DBus-Backend eraro: konekto al helpilo malsukcesis. %1\n"
"(aplikaĵo: %2 helpilo: %3)"

#: backends/dbus/DBusHelperProxy.cpp:134
#, qt-format
msgctxt "KAuth::DBusHelperProxy|"
msgid ""
"DBus Backend error: could not contact the helper. Connection error: %1. "
"Message error: %2"
msgstr ""
"DBus-Backend eraro: ne povis kontakti la helpilon. Konekt-eraro: %1. Mesaĝ-"
"eraro: %2"

#: executejob.cpp:84
msgctxt "KAuth::ExecuteJob|"
msgid "Tried to start an invalid action"
msgstr "Provis lanĉi nevalidan agon"

#: executejob.cpp:102
msgctxt "KAuth::ExecuteJob|"
msgid "Unknown execution mode chosen"
msgstr "Elektis nekonatan rulreĝimon"

#: executejob.cpp:147
msgctxt "KAuth::ExecuteJob|"
msgid "Unknown status for the authentication procedure"
msgstr "Nekonata statuso por la aŭtentiga proceduro"

#: executejob.cpp:159
msgctxt "KAuth::ExecuteJob|"
msgid ""
"The current backend only allows helper authorization, but this action does "
"not have a helper."
msgstr ""
"La aktuala backend permesas nur helpilan aŭtentigon, sed ĉi tiu ago ne havas "
"helpilon."

#: executejob.cpp:167 executejob.cpp:191
msgctxt "KAuth::ExecuteJob|"
msgid "The backend does not specify how to authorize"
msgstr "La backend ne specifas kiel aŭtentigi"
