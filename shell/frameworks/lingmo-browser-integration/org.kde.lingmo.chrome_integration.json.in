{
  "name": "org.kde.lingmo.browser_integration",
  "description": "Native connector for KDE Lingmo",
  "path": "@KDE_INSTALL_FULL_BINDIR@/lingmo-browser-integration-host",
  "type": "stdio",
  "allowed_origins": [
    "chrome-extension://@CHROME_EXTENSION_ID@/",
    "chrome-extension://@EDGE_EXTENSION_ID@/"
  ]
}
