#: ui/DeviceList.qml:25
#, kde-format
msgid "Enable Thunderbolt devices"
msgstr "Активиране на Thunderbolt устройства"

#: ui/DeviceList.qml:60
#, kde-format
msgid "No Thunderbolt devices connected"
msgstr "Няма свързани устройства Thunderbolt"

#: ui/DeviceList.qml:61
#, kde-format
msgid "Plug in a Thunderbolt device"
msgstr "Включване на Thunderbolt устройство"

#: ui/DeviceView.qml:62
#, kde-format
msgid "Vendor:"
msgstr "Доставчик:"

#: ui/DeviceView.qml:66
#, kde-format
msgid "UID:"
msgstr "UID:"

#: ui/DeviceView.qml:70
#, kde-format
msgid "Status:"
msgstr "Състояние:"

#: ui/DeviceView.qml:75
#, kde-format
msgid "Authorized at:"
msgstr "Разрешено на:"

#: ui/DeviceView.qml:80
#, kde-format
msgid "Connected at:"
msgstr "Свързан на:"

#: ui/DeviceView.qml:85
#, kde-format
msgid "Enrolled at:"
msgstr "Записан на:"

#: ui/DeviceView.qml:89
#, kde-format
msgid "Yes"
msgstr "Да"

#: ui/DeviceView.qml:89
#, kde-format
msgid "No"
msgstr "Не"

#: ui/DeviceView.qml:90
#, kde-format
msgid "Trusted:"
msgstr "Доверен:"

#: ui/DeviceView.qml:99
#, kde-format
msgid "Authorizing..."
msgstr "Упълномощаване..."

#: ui/DeviceView.qml:99
#, kde-format
msgid "Authorize"
msgstr "Упълномощаване"

#: ui/DeviceView.qml:110 ui/DeviceView.qml:130
#, kde-format
msgid "Failed to enroll device <b>%1</b>: %2"
msgstr "Неуспешно записване на устройство <b>%1 </b>:%2"

#: ui/DeviceView.qml:117
#, kde-format
msgid "Trust this Device"
msgstr "Доверяване на това устройство"

#: ui/DeviceView.qml:138
#, kde-format
msgid "Revoke Trust"
msgstr "Отмяна на доверието"

#: ui/DeviceView.qml:150
#, kde-format
msgid "Error changing device trust: <b>%1</b>: %2"
msgstr "Грешка при промяна на доверието на устройството: <b>%1 </b>:%2"

#: ui/DeviceView.qml:167
#, kde-format
msgid ""
"Hint: trusted device will be automatically authorized the next time it is "
"connected to the computer."
msgstr ""
"Съвет: довереното устройство ще бъде автоматично упълномощено следващия път, "
"когато е свързано към компютъра."

#: ui/DeviceView.qml:168
#, kde-format
msgid ""
"Hint: an untrusted device needs to be manually authorized each time it is "
"connected to the computer."
msgstr ""
"Съвет: Надеждното устройство трябва да бъде упълномощено ръчно всеки път, "
"когато е свързано към компютъра."

#: ui/main.qml:33
#, kde-format
msgid "Thunderbolt support has been disabled in BIOS"
msgstr "Поддръжката на Thunderbolt е забранена в BIOS"

#: ui/main.qml:34
#, kde-format
msgid "Follow your system manufacturer's guide to enable Thunderbolt support"
msgstr ""
"Следвайте ръководството на производителя на вашата система, за да активирате "
"поддръжката на Thunderbolt"

#: ui/main.qml:42
#, kde-format
msgid "Thunderbolt subsystem is disabled or unavailable"
msgstr "Подсистемата Thunderbolt не е налична или не е активирана"

#: ui/main.qml:43
#, kde-format
msgid ""
"If the device supports Thunderbolt, try plugging in a Thunderbolt device"
msgstr ""
"Ако устройството поддържа Thunderbolt, опитайте да включите Thunderbolt "
"устройството"

#: ui/utils.js:16
msgid "Disconnected"
msgstr "Прекъснат"

#: ui/utils.js:18
msgid "Connecting"
msgstr "Свързване"

#: ui/utils.js:20
msgid "Connected"
msgstr "Свързано"

#: ui/utils.js:23
msgid "Authorization Error"
msgstr "Грешка при упълномощаването"

#: ui/utils.js:25
msgid "Authorizing"
msgstr "Упълномощаване"

#: ui/utils.js:29
msgid "Reduced Functionality"
msgstr "Намалена функционалност"

#: ui/utils.js:31
msgid "Connected & Authorized"
msgstr "Свързан и оторизиран"

#: ui/utils.js:38
msgid "Trusted"
msgstr "Доверен"
