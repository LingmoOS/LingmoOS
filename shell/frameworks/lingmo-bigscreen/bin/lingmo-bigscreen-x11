#!/bin/sh

[ -f /etc/profile ] && . /etc/profile

export QT_QPA_PLATFORMTHEME=KDE

export QT_QUICK_CONTROLS_STYLE=Lingmo
export QT_ENABLE_GLYPH_CACHE_WORKAROUND=1
export QT_QUICK_CONTROLS_MOBILE=true
export LINGMO_PLATFORM=mediacenter
export QT_IM_MODULE=qtvirtualkeyboard
export QT_VIRTUALKEYBOARD_STYLE=Lingmo
export QT_FILE_SELECTORS=mediacenter

export LINGMO_DEFAULT_SHELL=org.kde.lingmo.mycroft.bigscreen
startlingmo-x11
