<refnamediv>
<refname
><command
>lingmoengineexplorer</command
></refname>
<refpurpose
>Levert directe toegang tot lingmo data-engines</refpurpose>
</refnamediv>

<refsynopsisdiv>
<cmdsynopsis
><command
>lingmoengineexplorer</command
> <group choice="opt"
><option
>-v, --version</option
></group
> <group choice="opt"
><option
>-h, --help</option
></group
> <group choice="opt"
><option
