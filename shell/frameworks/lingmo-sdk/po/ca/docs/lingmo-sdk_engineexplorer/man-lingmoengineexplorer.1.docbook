<refnamediv>
<refname
><command
>lingmoengineexplorer</command
></refname>
<refpurpose
>Proporciona accés directe als motors de dades de lingmo</refpurpose>
</refnamediv>

<refsynopsisdiv>
<cmdsynopsis
><command
>lingmoengineexplorer</command
> <group choice="opt"
><option
>-v, --version</option
></group
