><option
>--height</option
> <replaceable
>píxels</replaceable
></group
> <group choice="opt"
><option
>--width</option
> <replaceable
>píxels</replaceable
></group
> <group choice="opt"
><option
>-x</option
> <replaceable
>píxels</replaceable
></group
> <group choice="opt"
><option
>-y</option
> <replaceable
>píxels</replaceable
></group
> <group choice="opt"
><option
>--engine</option
> <replaceable
>motor de dades</replaceable
></group
