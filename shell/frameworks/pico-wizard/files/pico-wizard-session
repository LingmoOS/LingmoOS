[ -f /etc/profile ] && . /etc/profile

export QT_QPA_PLATFORM=wayland
export QT_QPA_PLATFORMTHEME=KDE
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export EGL_PLATFORM=wayland

export QT_QUICK_CONTROLS_STYLE=org.kde.ocean
export QT_ENABLE_GLYPH_CACHE_WORKAROUND=1
export QT_QUICK_CONTROLS_MOBILE=true
export LINGMO_INTEGRATION_USE_PORTAL=1
export LINGMO_PLATFORM=phone:handset
export QT_VIRTUALKEYBOARD_STYLE=Lingmo

export GRID_UNIT_PX=25
export FORCE_RIL_NUM_MODEMS=1

startlingmo-wayland --xwayland --inputmethod maliit-keyboard --exit-with-session=pico-wizard-wrapper
